{
  "name": "shorpin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' concurrently --kill-others --names mock,app \"node --experimental-strip-types mocks/server.ts\" \"react-router dev --mode mock\"",
    "dev:supabase": "react-router dev",
    "prepare": "node --input-type=module -e \"import { existsSync } from 'node:fs'; if (existsSync('scripts/install-git-hooks.mjs')) await import('./scripts/install-git-hooks.mjs');\"",
    "build": "react-router build",
    "build:preview": "react-router build --mode preview",
    "build:analyse": "react-router build --mode analyse",
    "start": "NODE_ENV=production NODE_OPTIONS='--import ./instrument.server.mjs' react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsgo",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --config oxlint.json",
    "lint:fix": "oxlint --fix --config oxlint.json",
    "verify": "pnpm fmt && pnpm lint && pnpm typecheck && pnpm fmt:check",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "knip": "knip",
    "test": "vitest",
    "test:e2e": "playwright test --config playwright.supabase.config.ts",
    "test:integration": "node scripts/test-integration.mjs"
  },
  "dependencies": {
    "@conform-to/react": "1.17.1",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.5",
    "@sentry/profiling-node": "^10.47.0",
    "@sentry/react-router": "^10.47.0",
    "@supabase/realtime-js": "^2.98.0",
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "2.98.0",
    "isbot": "5.1.35",
    "linkify-it": "^5.0.0",
    "motion": "12.34.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.14.0",
    "remix-toast": "4.0.0",
    "sonner": "2.0.7",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@msw/data": "1.1.2",
    "@playwright/test": "1.58.2",
    "@react-router/dev": "7.14.0",
    "@types/linkify-it": "^5.0.0",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vanilla-extract/css": "1.18.0",
    "@vanilla-extract/vite-plugin": "5.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "9.2.1",
    "knip": "6.3.0",
    "msw": "2.12.10",
    "oxfmt": "0.36.0",
    "oxlint": "^1.51.0",
    "react-router-devtools": "6.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "supabase": "2.76.16",
    "typescript": "5.9.3",
    "vite": "8.0.5",
    "vite-plugin-babel": "1.6.0",
    "vite-plugin-devtools-json": "1.0.0",
    "vitest": "4.1.3",
    "ws": "8.20.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "packageManager": "pnpm@9.10.0+sha512.73a29afa36a0d092ece5271de5177ecbf8318d454ecd701343131b8ebc0c1a91c487da46ab77c8e596d6acf1461e3594ced4becedf8921b074fbd8653ed7051c",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
